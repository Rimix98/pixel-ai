{
  "appId": "com.pixelai.app",
  "productName": "Pixel AI",
  "directories": {
    "buildResources": "resources",
    "output": "dist-win10"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/appIcon.ico"
  }
}
